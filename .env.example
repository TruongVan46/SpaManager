# ====================================================================
# SpaManager Environment Configuration Template (.env.example)
# ====================================================================

# --- Application Configurations ---
APP_NAME=SpaManager
APP_VERSION=4.0.0
FLASK_ENV=production

# --- Flask Core Security ---
SECRET_KEY=spa_manager_2026_secret_key

# --- Database Configurations ---
# Local SQLite Edition (Fallback Default):
# DATABASE_URL=sqlite:///database/spa.db
#
# PostgreSQL Cloud Edition (Railway / Render / Supabase):
# DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_URL=

# --- Deployment Environment ---
# Options: development | testing | production
APP_ENV=development

# --- PostgreSQL Migration (used by migrate_to_postgres.py only) ---
# SQLITE_DB_PATH=database/spa.db
# POSTGRES_URL=postgresql://user:password@host:5432/spadb

# --- Server Limits & Session Caching ---
MAX_UPLOAD_SIZE=104857600
SESSION_LIFETIME_DAYS=30
SEND_FILE_MAX_AGE_DAYS=365

# --- Default Owner Seed ---
# Override the initial owner account created on first startup.
DEFAULT_OWNER_USERNAME=owner
DEFAULT_OWNER_PASSWORD=owner123
DEFAULT_OWNER_EMAIL=

# --- Log Management ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION_SIZE=5242880
LOG_BACKUP_COUNT=5

# --- Google OAuth 2.0 API Settings ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_SCOPES=openid email profile
