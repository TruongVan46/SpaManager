# SpaManager environment template
# Copy this file to `.env` and adjust values for your environment.

# --- Application ---
APP_NAME=SpaManager
APP_VERSION=6.6
# APP_ENV is mandatory. Missing or unsupported values will cause startup to fail.
# Accepted values: development, testing, production
APP_ENV=development

APP_TIMEZONE=Asia/Ho_Chi_Minh
# Staged Approval Portal only; keep disabled until separately approved.
PERMANENT_PURGE_UI_ENABLED=0
# Destructive execution kill switch; keep disabled unless explicitly approved for the environment.
PERMANENT_PURGE_EXECUTION_ENABLED=0
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_FAILURE_WINDOW_SECONDS=600
LOGIN_LOCKOUT_SECONDS=600

# --- Security ---
# Keep this strong and private.
SECRET_KEY=change-this-to-a-long-random-secret
CSRF_ENABLED=1
CSRF_TIME_LIMIT=3600

# --- Database ---
# PostgreSQL local development:
DATABASE_URL=postgresql://<user>:<password>@localhost:5433/<db>
# PostgreSQL test database:
TEST_DATABASE_URL=postgresql://<user>:<password>@localhost:5433/<test_db>
# Railway production:
# DATABASE_URL=<Railway PostgreSQL reference variable>
# Legacy SQLite fallback (not recommended for product mode):
# SPA_ENABLE_SQLITE_LEGACY=1
# When enabled, leave DATABASE_URL unset to use the local SQLite fallback.
# Legacy PostgreSQL URL form is accepted and normalized to postgresql://
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB_NAME

# --- Default owner ---
DEFAULT_OWNER_USERNAME=owner
DEFAULT_OWNER_PASSWORD=change-this-to-a-strong-password
DEFAULT_OWNER_EMAIL=

# --- Approval owner ---
APPROVAL_OWNER_USERNAME=
APPROVAL_OWNER_EMAIL=
APPROVAL_OWNER_PASSWORD=

# --- Persistent storage ---
# Local development:
PERSISTENT_ROOT=database
# Railway production:
# PERSISTENT_ROOT=/app/database

# --- Storage / upload paths ---
# Leave blank to use defaults derived from PERSISTENT_ROOT.
UPLOAD_ROOT=
LOGO_UPLOAD_FOLDER=
AVATAR_UPLOAD_FOLDER=

# --- Runtime limits ---
MAX_UPLOAD_SIZE=104857600
SESSION_LIFETIME_DAYS=30
SEND_FILE_MAX_AGE_DAYS=365

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION_SIZE=5242880
LOG_BACKUP_COUNT=5

# --- Optional Google OAuth ---
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_ALLOWED_DOMAIN=
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_SCOPES=openid email profile
