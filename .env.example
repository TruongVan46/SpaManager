# ====================================================================
# SpaManager Environment Configuration Template
# ====================================================================

# --- Application ---
APP_NAME=SpaManager
APP_VERSION=5.0.0
APP_ENV=development
APP_TIMEZONE=Asia/Ho_Chi_Minh

# --- Security ---
# Required in production.
SECRET_KEY=change-me-before-deploy
# CSRF protection is enabled by default; no extra environment variable is required.

# --- Database ---
# Local development default:
# DATABASE_URL=sqlite:///database/spa.db
#
# Production on Railway:
# DATABASE_URL=

# --- Default Owner ---
# Required in production.
DEFAULT_OWNER_USERNAME=owner
DEFAULT_OWNER_PASSWORD=change-me-local-only
DEFAULT_OWNER_EMAIL=

# --- Persistent Storage ---
# Local default: database
# Railway default: /app/database
PERSISTENT_ROOT=database
UPLOAD_ROOT=
LOGO_UPLOAD_FOLDER=
AVATAR_UPLOAD_FOLDER=

# --- Upload ---
MAX_UPLOAD_SIZE=104857600

# --- Session ---
SESSION_LIFETIME_DAYS=30
SEND_FILE_MAX_AGE_DAYS=365

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION_SIZE=5242880
LOG_BACKUP_COUNT=5

# --- Optional Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_SCOPES=openid email profile
